# Family Photo Identifier - Git Ignore File
# Prevents sensitive data, large files, and environment-specific files from being committed

# ============================================================================
# Python Virtual Environment
# ============================================================================
venv/
env/
ENV/
.venv/
.ENV/

# ============================================================================
# Data Files - Training, Testing, and Model Files
# ============================================================================
# Training data (personal photos)
data/training/**
!data/training/.gitkeep
*.dat

# Testing data
data/testing/**
!data/testing/.gitkeep

# Trained models (can be large)
data/models/**
!data/models/.gitkeep

# Keep directory structure but ignore contents
data/**/
!data/**/.gitkeep

# ============================================================================
# Log Files
# ============================================================================
logs/
*.log
*.log.*

# ============================================================================
# Environment and Configuration Files with Secrets
# ============================================================================
.env
.env.local
.env.*.local
*.key
secrets.json

# Keep example files
!.env.example

# ============================================================================
# Python Cache and Compiled Files
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ============================================================================
# Build and Distribution
# ============================================================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

